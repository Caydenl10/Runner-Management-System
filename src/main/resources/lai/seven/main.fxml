<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lai.seven.MainController">

    <!-- Background Image -->
    <ImageView fx:id="backgroundImage" fitWidth="800" fitHeight="800" preserveRatio="false">
        <image>
            <Image url="@background.jpg" />
        </image>
    </ImageView>

    <!-- Foreground Content -->
    <AnchorPane prefWidth="800.0" prefHeight="800.0">
        <VBox layoutX="20.0" layoutY="20.0" spacing="20.0" prefWidth="760.0">
            
            <!-- Title and Image -->
            <Label fx:id="hiLabel" text="Welcome!" style="-fx-text-fill: white;" />
            <ImageView fx:id="myImageView" fitHeight="180" fitWidth="300" preserveRatio="true" />

            <!-- Search Bar -->
            <HBox spacing="10">
                <ComboBox fx:id="filterComboBox" prefWidth="120" />
                <TextField fx:id="searchField" prefWidth="200" promptText="Search..." />
                <Button fx:id="searchButton" onAction="#handleSearchButton" text="Search" />
            </HBox>

            <!-- Mirrored Form Fields -->
            <HBox spacing="50" alignment="CENTER">
                <VBox spacing="10" prefWidth="350">
                    <Label text="Runner ID:" style="-fx-text-fill: white;" />
                    <TextField fx:id="runnerIDField" editable="false" />

                    <Label text="First Name:" style="-fx-text-fill: white;" />
                    <TextField fx:id="firstNameField" />

                    <Label text="Age:" style="-fx-text-fill: white;" />
                    <TextField fx:id="ageField" />
                </VBox>

                <VBox spacing="10" prefWidth="350">
                    <Label text="Last Name:" style="-fx-text-fill: white;" />
                    <TextField fx:id="lastNameField" />

                    <Label text="Gender:" style="-fx-text-fill: white;" />
                    <ComboBox fx:id="genderComboBox" />

                    <Label text="Distance:" style="-fx-text-fill: white;" />
                    <TextField fx:id="distanceField" />
                </VBox>
            </HBox>

            <!-- Bottom Row Fields -->
            <HBox spacing="20" alignment="CENTER_LEFT">
                <Label text="Injured:" style="-fx-text-fill: white;" />
                <CheckBox fx:id="injuredCheckBox" />
            </HBox>

            <!-- Navigation Buttons -->
            <HBox alignment="CENTER" spacing="10">
                <Button fx:id="firstButton" onAction="#handleFirstButton" text="|◄" />
                <Button fx:id="prevFiveButton" onAction="#handlePrevFiveButton" text="◄◄" />
                <Button fx:id="prevButton" onAction="#handlePrevButton" text="◄" />
                <Button fx:id="nextButton" onAction="#handleNextButton" text="►" />
                <Button fx:id="nextFiveButton" onAction="#handleNextFiveButton" text="►►" />
                <Button fx:id="lastButton" onAction="#handleLastButton" text="►|" />
            </HBox>

            <!-- CRUD Buttons -->
            <HBox alignment="CENTER" spacing="10">
                <Button fx:id="createButton" onAction="#handleCreateButton" text="Insert" />
                <Button fx:id="deleteButton" onAction="#handleDeleteButton" text="Delete" />
                <Button fx:id="updateButton" onAction="#handleUpdateButton" text="Update" />
            </HBox>
        </VBox>

        <!-- Top-Right Controls -->
        <Button fx:id="connectToggleButton" layoutX="700.0" layoutY="20.0" onAction="#handleConnectToggle" prefWidth="80" text="Connect" />
        <Button fx:id="exportButton" layoutX="700.0" layoutY="60.0" onAction="#handleExportButton" text="Export CSV" />
    </AnchorPane>
</StackPane>
